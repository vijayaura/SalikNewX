# ── Local dev (with Ollama) ──────────────────────────────────────────
# 1. Install Ollama: https://ollama.com/download
# 2. Run: ollama pull llama3.2
# 3. Copy this file to .env and start: npm run dev
VITE_OLLAMA_URL=/api/ollama
VITE_OLLAMA_MODEL=llama3.2
VITE_AI_ENABLED=true

# ── Production / static deploy (GitHub Pages, Vercel, etc.) ────────
# Chat works without Ollama — built-in smart answers handle all FAQs.
# Leave VITE_OLLAMA_URL unset (or empty) in your CI/build environment.
# VITE_AI_ENABLED=true
# VITE_BASE_PATH=/SalikNewX/

# ── Production with remote Ollama server ─────────────────────────────
# VITE_OLLAMA_URL=https://your-ollama-host.example.com
# VITE_OLLAMA_MODEL=llama3.2
# Set OLLAMA_ORIGINS on the server to your deploy domain.
