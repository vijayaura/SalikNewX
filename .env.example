# ── Claude via Azure Foundry (from Azure portal) ────────────────────
ANTHROPIC_API_KEY=your_api_key_here
ANTHROPIC_FOUNDRY_BASE_URL=https://your-resource.services.ai.azure.com/anthropic
ANTHROPIC_FOUNDRY_RESOURCE=your-resource
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MAX_TOKENS=512
ANTHROPIC_TEMPERATURE=0.35

# ── Or direct Anthropic API (sk-ant- keys from console.anthropic.com) ─
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Frontend
VITE_AI_ENABLED=true
